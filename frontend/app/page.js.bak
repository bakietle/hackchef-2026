'use client'
import { useState } from 'react'
import { useRouter } from 'next/navigation'
import MamaIdle from '@/components/mama/MamaIdle'
import { usePlannerStore } from '@/lib/plannerStore'

// Retro food illustrations as inline SVG
function FoodDeco({ style }) {
  return (
    <svg width="40" height="40" viewBox="0 0 40 40" style={style}>
      {/* simple retro lemon */}
      <ellipse cx="20" cy="20" rx="16" ry="14" fill="#F5C842" stroke="#1B2B4B" strokeWidth="1.5" />
      <ellipse cx="20" cy="20" rx="10" ry="8" fill="#FFF8DC" opacity=".5" />
      <line x1="20" y1="6" x2="20" y2="34" stroke="#E8B820" strokeWidth="1" />
      <line x1="7" y1="14" x2="33" y2="26" stroke="#E8B820" strokeWidth="1" />
      <line x1="7" y1="26" x2="33" y2="14" stroke="#E8B820" strokeWidth="1" />
    </svg>
  )
}

function StarDeco({ style, size = 16 }) {
  return (
    <svg width={size} height={size} viewBox="0 0 16 16" style={style}>
      <path d="M8 1 L9.5 6 L14.5 6 L10.5 9.5 L12 14.5 L8 11.5 L4 14.5 L5.5 9.5 L1.5 6 L6.5 6Z" fill="#F5C842" stroke="#1B2B4B" strokeWidth="1" />
    </svg>
  )
}

export default function WelcomePage() {
  const router = useRouter()
  const setUserName = usePlannerStore(s => s.setUserName)
  const [name, setName] = useState('')

  const handleStart = () => {
    setUserName(name.trim() || 'Foodie')
    router.push('/home')
  }

  return (
    <div style={{
      minHeight:'100vh',
      background:'linear-gradient(160deg, #1B2B4B 0%, #2C4270 45%, #1B3A5A 100%)',
      display:'flex', flexDirection:'column',
      alignItems:'center', justifyContent:'center',
      padding:'32px 24px', textAlign:'center',
      position:'relative', overflow:'hidden',
    }}>
      {/* Retro background pattern */}
      <div style={{ position:'absolute', inset:0, pointerEvents:'none', overflow:'hidden' }}>
        {/* big circle top right */}
        <div style={{ position:'absolute', top:-60, right:-60, width:220, height:220, borderRadius:'50%', background:'rgba(245,200,66,0.1)', border:'2px solid rgba(245,200,66,0.15)' }} />
        <div style={{ position:'absolute', top:-20, right:-20, width:120, height:120, borderRadius:'50%', background:'rgba(245,200,66,0.08)' }} />
        {/* circle bottom left */}
        <div style={{ position:'absolute', bottom:-80, left:-60, width:250, height:250, borderRadius:'50%', background:'rgba(245,200,66,0.07)', border:'2px solid rgba(245,200,66,0.1)' }} />
        {/* food decos */}
        <FoodDeco style={{ position:'absolute', top:80, left:20, opacity:.6, transform:'rotate(-15deg)' }} />
        <FoodDeco style={{ position:'absolute', top:120, right:24, opacity:.5, transform:'rotate(20deg)' }} />
        <FoodDeco style={{ position:'absolute', bottom:180, left:30, opacity:.4, transform:'rotate(10deg)' }} />
        {/* stars */}
        <StarDeco style={{ position:'absolute', top:60, left:'40%', opacity:.5 }} />
        <StarDeco style={{ position:'absolute', top:200, right:60, opacity:.4 }} size={10} />
        <StarDeco style={{ position:'absolute', bottom:220, right:40, opacity:.5 }} size={12} />
        <StarDeco style={{ position:'absolute', bottom:300, left:50, opacity:.35 }} size={8} />
        {/* horizontal retro lines */}
        <div style={{ position:'absolute', top:'35%', left:0, right:0, height:'1px', background:'rgba(245,200,66,0.08)' }} />
        <div style={{ position:'absolute', top:'65%', left:0, right:0, height:'1px', background:'rgba(245,200,66,0.06)' }} />
      </div>

      <div style={{ position:'relative', zIndex:1, width:'100%', maxWidth:380 }}>
        {/* App tag */}
        <div style={{
          display:'inline-flex', alignItems:'center', gap:6,
          background:'var(--yellow)', border:'2px solid var(--navy)',
          borderRadius:8, padding:'4px 14px', marginBottom:20,
          boxShadow:'3px 3px 0 rgba(245,200,66,0.25)',
        }}>
          <span style={{ fontSize:11, fontWeight:900, letterSpacing:2, color:'var(--navy)', textTransform:'uppercase', fontFamily:'Nunito, sans-serif' }}>
            Nomster 🍳
          </span>
        </div>

        {/* Mama */}
        <div className="mama-float">
          <MamaIdle size={145} />
        </div>

        {/* Speech bubble */}
        <div style={{
          background:'var(--white)', border:'2px solid var(--navy)',
          borderRadius:'18px 18px 18px 6px',
          padding:'12px 16px', maxWidth:220,
          margin:'6px auto 20px', lineHeight:1.65,
          fontSize:13, fontWeight:700, color:'var(--navy)',
          boxShadow:'3px 4px 0 rgba(0,0,0,0.2)',
        }}>
          hey! mama's here to keep u actually fed this week 🥄
        </div>

        {/* Headline */}
        <h1 style={{
          fontFamily:'Fraunces, serif',
          fontSize:30, fontWeight:900,
          color:'var(--yellow)',
          marginBottom:6, letterSpacing:'-0.3px',
          lineHeight:1.2,
        }}>ur meal mama</h1>
        <p style={{ fontSize:13, color:'rgba(255,255,255,0.55)', marginBottom:28, fontWeight:600 }}>
          real food · every week · no stress
        </p>

        {/* Input card */}
        <div style={{
          background:'rgba(255,255,255,0.07)',
          border:'2px solid rgba(245,200,66,0.3)',
          borderRadius:20, padding:'20px 18px',
        }}>
          <div style={{ fontSize:12, fontWeight:800, color:'rgba(255,255,255,0.65)', textTransform:'uppercase', letterSpacing:1, marginBottom:10, textAlign:'left', fontFamily:'Nunito, sans-serif' }}>
            what should mama call you?
          </div>
          <input
            style={{
              width:'100%',
              background:'rgba(255,255,255,0.1)',
              border:'2px solid rgba(245,200,66,0.4)',
              borderRadius:12, padding:'14px 16px',
              fontSize:16, fontFamily:'Nunito, sans-serif',
              outline:'none', fontWeight:700, color:'var(--white)',
              marginBottom:14,
            }}
            placeholder="e.g. Alex 🍴"
            value={name}
            onChange={e => setName(e.target.value)}
            onKeyDown={e => e.key === 'Enter' && handleStart()}
            autoFocus
          />
          <button onClick={handleStart} style={{
            width:'100%', padding:15, borderRadius:12,
            border:'2px solid var(--navy)',
            background:'var(--yellow)', color:'var(--navy)',
            fontSize:16, fontWeight:900, cursor:'pointer',
            fontFamily:'Nunito, sans-serif',
            boxShadow:'3px 4px 0 rgba(27,43,75,0.5)',
            transition:'transform .1s, box-shadow .1s',
          }}
            onMouseDown={e => { e.currentTarget.style.transform='translate(2px,3px)'; e.currentTarget.style.boxShadow='0 0 0 rgba(27,43,75,0.5)' }}
            onMouseUp={e => { e.currentTarget.style.transform=''; e.currentTarget.style.boxShadow='3px 4px 0 rgba(27,43,75,0.5)' }}
          >
            let's cook! 🍽️
          </button>
        </div>
      </div>
    </div>
  )
}
